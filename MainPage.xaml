<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             xmlns:controls="clr-namespace:Student_Tracker_App"
             x:Class="Student_Tracker_App.MainPage"
             NavigationPage.HasNavigationBar="False"
             
             Loaded="ContentPage_Loaded">

    <VerticalStackLayout
            Padding="20"
            Spacing="20">
        <controls:HeaderControl />

        <Grid VerticalOptions="Fill" MinimumHeightRequest="450">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">

                <Label x:Name="WelcomeLabel"
               Text="Welcome"
               TextColor="Black"
               FontAttributes="Bold"
               FontSize="40"
               Opacity="0"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,20"/>

                <Entry x:Name="UsernameEntry" 
               Placeholder="Username" 
               WidthRequest="250" />

                <Entry x:Name="PasswordEntry" 
               Placeholder="Password" 
               IsPassword="True" 
               WidthRequest="250" />

                <Button x:Name="LoginBtn"
                Text="Login"
                FontAttributes="Bold"
                TextColor="White"
                BackgroundColor="#3949ab"
                FontSize="18"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="250"
                Clicked="OnLoginClicked" />

                <Button x:Name="RegisterBtn"
                Text="Create Account"
                FontAttributes="Bold"
                TextColor="#3949ab"
                BackgroundColor="Transparent"
                BorderColor="#3949ab"
                BorderWidth="1"
                FontSize="18"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="250"
                Clicked="OnRegisterClicked" />

            </VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>

</ContentPage>
