<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             xmlns:controls="clr-namespace:C971_Mobile_App_PA"
             x:Class="C971_Mobile_App_PA.MainPage"
             NavigationPage.HasNavigationBar="False"
             
             Loaded="ContentPage_Loaded">

    <VerticalStackLayout
            Padding="20"
            Spacing="20">
        <controls:HeaderControl />

        <Grid VerticalOptions="Fill" MinimumHeightRequest="450">
            <Label
                    x:Name="WelcomeLabel"
                    Text="Welcome"
                    TextColor="Black"
                    FontAttributes="Bold"
                    FontSize="40"
                    Opacity="0"
                    Margin="0,-110,0,0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HorizontalTextAlignment="Center"/>
            <Button
                x:Name="TermsBtn"
                Text="View Terms List"
                FontAttributes="Bold"
                TextColor="White"
                BackgroundColor="#3949ab"
                FontSize="18"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="220"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Clicked="OnTermsClicked"
                Margin="0,20,0,0" />
        </Grid>
    </VerticalStackLayout>

</ContentPage>
