<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             xmlns:controls="clr-namespace:Student_Tracker_App"
             
             x:Class="Student_Tracker_App.Views.TermEditAdd"
             Title="TermEditAdd">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">
            <controls:HeaderControl />
            <VerticalStackLayout>
                <Label Text="Term Title"
                       FontSize="16"
                       FontAttributes="Bold" />
                <Entry Text="{Binding TermTitle}"
                       Placeholder="Enter term title (e.g., Spring 2026)"
                       ClearButtonVisibility="WhileEditing"/>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Start Date"
                       FontSize="16"
                       FontAttributes="Bold" />
                <DatePicker x:Name="StartDatePicker"
                                Date="{Binding TermStart}"
                                Format="MM/dd/yyyy"
                                DateSelected="DatePicker_DateSelected" />
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="End Date"
                       FontSize="16"
                       FontAttributes="Bold" />
                <DatePicker x:Name="EndDatePicker"
                                Date="{Binding TermEnd}"
                                Format="MM/dd/yyyy"
                                DateSelected="DatePicker_DateSelected" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="20" Margin="0,20,0,0">
                <Button Text="Save"
                        BackgroundColor="#3949ab"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        Grid.Column="0"
                        Clicked="OnSaveClicked"/>
                <Button Text="Cancel"
                        BackgroundColor="#D32F2F"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        Grid.Column="1"
                        Clicked="OnCancelClicked"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>