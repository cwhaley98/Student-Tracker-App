<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             xmlns:controls="clr-namespace:C971_Mobile_App_PA"
             
             x:Class="C971_Mobile_App_PA.Views.TermsList"
             Title="Terms List">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add Term" 
                     Clicked="OnAddTermClicked" 
                     Priority="0" 
                     Order="Primary" />
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout>
            <Border x:Name="SuccessBanner"
                BackgroundColor="#D4EDDA"
                Stroke="#C3E6CB"
                StrokeThickness="1"
                HeightRequest="50"
                Margin="20,10,20,0"
                Padding="10"
                IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label x:Name="SuccessLabel"
                   Text="Action Successful"
                   TextColor="#155724"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            </Border>

            <controls:HeaderControl />

            <Label Text="Terms List" 
               FontSize="28" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="Black" 
               Margin="0,20,0,10" />

            <CollectionView x:Name="TermsCollection" Margin="20,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="Black" StrokeThickness="1" Margin="0,0,0,10" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="20">
                                <Label Text="{Binding Path=TermTitle}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Start"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       TextColor="Black">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnTermSelected"
                                            CommandParameter="{Binding Path=.}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <ImageButton Grid.Column="1"
                                             Padding="5"
                                             Source="edit.png"
                                             HeightRequest="5"
                                             WidthRequest="5"
                                             Clicked="OnEditClicked"
                                             CommandParameter="{Binding Path=.}" />
                                <ImageButton Grid.Column="2"
                                             Padding="5"
                                             Source="delete.png"
                                             HeightRequest="5"
                                             WidthRequest="5"
                                             Clicked="OnDeleteClicked"
                                             CommandParameter="{Binding Path=.}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>