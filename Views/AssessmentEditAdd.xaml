<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Student_Tracker_App"
             x:Class="Student_Tracker_App.Views.AssessmentEditAdd"
             Title="Assessment Details">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="0,0,0,20">
            <controls:HeaderControl />

            <Label Text="Assessment Details" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black"/>

            <VerticalStackLayout Padding="20" Spacing="10">

                <Label Text="Assessment Title" FontAttributes="Bold"/>
                <Entry Text="{Binding AssessmentTitle}" Placeholder="e.g., Create Wireframes" />

                <Label Text="Assessment Type" FontAttributes="Bold"/>
                <Picker SelectedItem="{Binding AssessmentType}" Title="Select Type">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Objective</x:String>
                            <x:String>Performance</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>

                <Label Text="Start Date" FontAttributes="Bold"/>
                <DatePicker Date="{Binding StartDate}" />

                <Label Text="End Date" FontAttributes="Bold"/>
                <DatePicker Date="{Binding EndDate}" />

                <Grid ColumnDefinitions="*, Auto" Margin="0,10">
                    <Label Text="Enable notifications?" VerticalOptions="Center" FontAttributes="Bold"/>
                    <Switch Grid.Column="1" IsToggled="{Binding notificationsEnabled}" />
                </Grid>

            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="20" Margin="20,0">
                <Button Text="Cancel" Grid.Column="0" BackgroundColor="#D32F2F" TextColor="White" Clicked="OnCancelClicked"/>
                <Button Text="Save" Grid.Column="1" BackgroundColor="#3949ab" TextColor="White" Clicked="OnSaveClicked"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>