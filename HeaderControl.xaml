<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C971_Mobile_App_PA.HeaderControl">

    <Border HeightRequest="100" 
            StrokeThickness="0"
            Margin="20,10">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15"/>
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow Brush="Black"
                    Offset="0,5"
                    Radius="10"
                    Opacity="0.2" />
        </Border.Shadow>

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#1a237e" Offset="0.1" />
                <GradientStop Color="#3949ab" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>

        <Image Source="wgulogo.png" 
               Aspect="AspectFit"
               HeightRequest="60"
               Margin="20,10"
               HorizontalOptions="Center" 
               VerticalOptions="Center" />
    </Border>
</ContentView>
